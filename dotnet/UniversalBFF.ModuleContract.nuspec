<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>UniversalBFF.ModuleContract</id>
    <version>1.0.0</version>
    <title>UniversalBFF.ModuleContract</title>
    <authors>KornSW and KeinIch</authors>
    <owners>(public domain)</owners>
    <copyright>KornSW and KeinIch</copyright>
    <description>API Contract for authors of application-modules that can be hosted within the UniversalBFF</description>
    <tags>BFF UShell SPA UJMW W3bstract</tags>
    <!-- https://spdx.org/licenses/ -->
    <license type="expression">GPL-3.0-only</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <icon>PackageIcon.png</icon>
    <projectUrl>https://github.com/KornSW/UniversalBFF</projectUrl>
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Newtonsoft.Json" version="[13.0.3,13.9999]" />
        <dependency id="SmartStandards.AuthTokenHandling" version="[5.0.0,6.0)" />
      </group>
       <group targetFramework="net10.0">
        <dependency id="Newtonsoft.Json" version="[13.0.4,13.9999]" />
        <dependency id="SmartStandards.AuthTokenHandling" version="[5.0.0,6.0)" />
      </group>     
    </dependencies>
  </metadata>
  <files>
    <!-- https://docs.microsoft.com/en-us/nuget/create-packages/creating-a-package#from-a-convention-based-working-directory -->
    <file src="PackageIcon.png" target="" /> 
    <!-- .NET 8.0 -->
    <file src="dist\bin-net8.0\UniversalBFF.ModuleContract.dll" target="lib/net8.0" />
    <file src="dist\bin-net8.0\UniversalBFF.ModuleContract.xml" target="lib/net8.0" />
    <file src="dist\bin-net8.0\UniversalBFF.ModuleContract.pdb" target="lib/net8.0" />
    <!-- .NET 10.0 -->
    <file src="dist\bin-net10.0\UniversalBFF.ModuleContract.dll" target="lib/net10.0" />
    <file src="dist\bin-net10.0\UniversalBFF.ModuleContract.xml" target="lib/net10.0" />
    <file src="dist\bin-net10.0\UniversalBFF.ModuleContract.pdb" target="lib/net10.0" />
  </files>
</package>
